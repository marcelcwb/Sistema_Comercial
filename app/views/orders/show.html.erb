<header class="page-head">
  <div>
    <p class="eyebrow">Pedido</p>
    <h1>Pedido #<%= @order.id %></h1>
    <p class="subtle"><%= @order.customer.name %> em <%= l(@order.ordered_on) %></p>
  </div>
  <div class="actions">
    <% if can?(:update, @order) %>
      <%= link_to "Editar", edit_order_path(@order), class: "button" %>
    <% end %>
    <%= link_to "Voltar", orders_path, class: "button secondary" %>
  </div>
</header>

<section class="grid">
  <article class="metric">
    <span>Status</span>
    <strong><%= @order.status.humanize %></strong>
  </article>
  <article class="metric">
    <span>Total</span>
    <strong><%= currency(@order.total) %></strong>
  </article>
  <article class="metric">
    <span>Itens</span>
    <strong><%= @order.order_items.count %></strong>
  </article>
  <article class="metric">
    <span>Financeiro</span>
    <strong><%= @order.financial_entry&.status&.humanize || "-" %></strong>
  </article>
</section>

<section class="panel">
  <h2>Itens do pedido</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Produto</th>
          <th>Quantidade</th>
          <th>Valor unitario</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% @order.order_items.includes(:product).each do |item| %>
          <tr>
            <td><%= item.product.name %></td>
            <td><%= item.quantity %></td>
            <td><%= currency(item.unit_price) %></td>
            <td><%= currency(item.subtotal) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
