<%= form_with(model: customer, class: "form-panel") do |form| %>
  <%= render "shared/errors", record: customer %>

  <div class="form-grid">
    <div class="field full">
      <%= form.label :name, "Nome" %>
      <%= form.text_field :name, required: true %>
    </div>
    <div class="field">
      <%= form.label :document, "Documento" %>
      <%= form.text_field :document %>
    </div>
    <div class="field">
      <%= form.label :email, "Email" %>
      <%= form.email_field :email %>
    </div>
    <div class="field">
      <%= form.label :phone, "Telefone" %>
      <%= form.text_field :phone %>
    </div>
    <div class="field">
      <%= form.label :city, "Cidade" %>
      <%= form.text_field :city %>
    </div>
    <div class="field">
      <%= form.label :state, "Estado" %>
      <%= form.text_field :state %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit "Salvar" %>
    <%= link_to "Cancelar", customers_path, class: "button secondary" %>
  </div>
<% end %>
