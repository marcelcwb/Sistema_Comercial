<div class="auth-page">
  <section class="auth-card">
    <p class="eyebrow">Nova senha</p>
    <h1>Alterar senha</h1>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |form| %>
      <%= render "shared/errors", record: resource %>
      <%= form.hidden_field :reset_password_token %>

      <div class="form-grid">
        <div class="field full">
          <%= form.label :password, "Nova senha" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password" %>
        </div>
        <div class="field full">
          <%= form.label :password_confirmation, "Confirmar nova senha" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
        </div>
      </div>

      <div class="form-actions">
        <%= form.submit "Alterar senha" %>
      </div>
    <% end %>
  </section>
</div>
