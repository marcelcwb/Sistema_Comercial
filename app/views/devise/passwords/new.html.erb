<div class="auth-page">
  <section class="auth-card">
    <p class="eyebrow">Recuperacao</p>
    <h1>Redefinir senha</h1>
    <p class="subtle">Informe seu email para receber as instrucoes.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |form| %>
      <%= render "shared/errors", record: resource %>

      <div class="form-grid">
        <div class="field full">
          <%= form.label :email, "Email" %>
          <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email" %>
        </div>
      </div>

      <div class="form-actions">
        <%= form.submit "Enviar instrucoes" %>
        <%= link_to "Voltar", new_user_session_path, class: "button secondary" %>
      </div>
    <% end %>
  </section>
</div>
