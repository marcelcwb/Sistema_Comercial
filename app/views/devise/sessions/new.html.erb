<div class="auth-page">
  <section class="auth-card">
    <p class="eyebrow">Acesso seguro</p>
    <h1>Entrar</h1>
    <p class="subtle">Use seu email e senha para acessar o sistema.</p>

    <% if notice.present? %>
      <p class="flash"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="flash alert"><%= alert %></p>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |form| %>
      <div class="form-grid">
        <div class="field full">
          <%= form.label :email, "Email" %>
          <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email" %>
        </div>
        <div class="field full">
          <%= form.label :password, "Senha" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password" %>
        </div>
        <% if devise_mapping.rememberable? %>
          <div class="field full checkbox-field">
            <%= form.check_box :remember_me %>
            <%= form.label :remember_me, "Lembrar acesso" %>
          </div>
        <% end %>
      </div>

      <div class="form-actions">
        <%= form.submit "Entrar" %>
      </div>
    <% end %>
  </section>
</div>
